/target
.env
*.lock
!Cargo.lock
.DS_Store
*.swp
*.swo
nohup.out

# Specs — internal build instructions, not for distribution
specs/

# Catalogue — internal documentation, not public yet
catalogue/

# Orchestration registry — internal tracking
orchestrations/

# Docs — not ready for public distribution yet
docs/

# Harness reports and logs — generated output
harness-reports/
harness-*.log
*.log

# Hydra runtime data
~/.hydra/

# User-specific connectors and integrations — never commit business configs
connectors/*.toml
integrations/*/credentials.toml

# Vault — all credentials, never commit
vault/*.toml
vault/hydra-created/*.toml
!vault/EXAMPLE.toml

# Disabled test harnesses
*.rs.disabled
docs/node_modules/
docs/build/
docs/.docusaurus/
